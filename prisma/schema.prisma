generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["relationJoins", "typedSql"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model contract_data {
  contract_id                String?
  ledger_sequence            Int
  key_hash                   String   @id
  durability                 String?
  key_symbol                 String?
  key                        Bytes?
  val                        Bytes?
  closed_at                  DateTime @db.Timestamptz(6)
  live_until_ledger_sequence Int?

  @@index([contract_id, key_hash, ledger_sequence(sort: Desc)], map: "idx_contract_data_contract_id_key_hash_ledger_sequence_desc_loa")
  @@index([contract_id, closed_at(sort: Desc), key_hash(sort: Desc)], map: "idx_contract_data_contract_id_closed_at")
  @@index([contract_id, durability(sort: Desc), key_hash(sort: Desc)], map: "idx_contract_data_contract_id_durability")
  @@index([contract_id, live_until_ledger_sequence(sort: Desc), key_hash(sort: Desc)], map: "idx_contract_data_contract_id_live_until")
}
